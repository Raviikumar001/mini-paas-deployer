{
  "admin": {
    "listen": "0.0.0.0:2019",
    "origins": ["", "caddy:2019", "localhost:2019"]
  },
  "apps": {
    "http": {
      "servers": {
        "srv0": {
          "listen": [":80"],
          "routes": [
            {
              "@id": "api",
              "match": [{ "path": ["/api/*"] }],
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [{ "dial": "backend:3001" }]
                }
              ]
            },
            {
              "@id": "frontend",
              "match": [{ "not": [{ "path": ["/p/*"] }] }],
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [{ "dial": "frontend:5173" }]
                }
              ]
            }
          ]
        }
      }
    }
  }
}
